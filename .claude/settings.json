{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "language": "korean",

  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push*)",

      "Bash(node *)",
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npx *)",

      "Bash(python -m http.server *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],

    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",

      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -xdf*)",

      "Bash(rm -rf*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$input | ConvertFrom-Json | ForEach-Object { $f = $_.tool_input.file_path; if (-not $f) { $f = $_.tool_response.filePath }; if ($f) { Write-Host \"[변경됨] $f\" } }",
            "statusMessage": "파일 변경 확인 중..."
          }
        ]
      }
    ]
  },

  "env": {
    "NODE_ENV": "development"
  },

  "cleanupPeriodDays": 90,
  "verbose": false,
  "autoCompactEnabled": true
}